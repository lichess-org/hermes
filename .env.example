# Base URL of this app (no trailing slash). Required in production for OAuth redirects.
APP_URL=http://localhost:5173

# Session signing secret. Use a long random string in production.
SESSION_SECRET=

# SQLite database file (default: ./data/hermes.db). In Docker, use e.g. /data/hermes.db with a volume.
DATABASE_PATH=

# Authentik OIDC issuer for your OAuth2/OIDC provider (Provider > View details > OpenID Configuration Issuer).
# Example: https://authentik.example.com/application/o/hermes/
AUTHENTIK_ISSUER=

AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Optional: port for production server (default 3000)
# PORT=3000
